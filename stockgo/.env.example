# Port d'écoute HTTP
PORT=8080

# development | production — production active le mode release Gin et les
# logs JSON structurés
ENV=development

# Connexion PostgreSQL (Railway fournit DATABASE_URL automatiquement en prod)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/stockgo_dev?sslmode=disable

# Secret de signature des JWT — obligatoire, chaîne aléatoire longue en prod
JWT_SECRET=change-me-in-production

# Clé API statique pour l'authentification service-à-service (l'application
# e-commerce l'envoie dans le header X-API-Key)
API_KEY=change-me-in-production

# Répertoire physique de stockage — en prod, chemin du Volume Railway monté
STORAGE_PATH=./uploads

# Taille max d'un upload, en octets (défaut 100 Mo)
MAX_UPLOAD_SIZE=104857600

# URL publique du service, utilisée pour construire les liens de téléchargement
PUBLIC_URL=http://localhost:8080

# Rate limiting par IP (requêtes/seconde et rafale autorisée)
RATE_LIMIT_RPS=5
RATE_LIMIT_BURST=15
