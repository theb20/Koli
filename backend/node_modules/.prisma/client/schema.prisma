// ══════════════════════════════════════════════════════════════
//  KOLI — Prisma Schema
//  SQLite en dev · PostgreSQL en prod
// ══════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── ENUMS ──────────────────────────────────────────────────────────

// SQLite ne supporte pas les enums natifs → on utilise String avec
// validation côté application (Zod)

// ── USER ───────────────────────────────────────────────────────────
model User {
  id         String    @id @default(cuid())
  email      String    @unique
  password   String
  prenom     String
  nom        String
  telephone  String?
  avatar     String?
  genre      String? // "Homme" | "Femme" | "Autre"
  naissance  DateTime?
  role       String    @default("customer") // "customer" | "admin"
  isVerified Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relations
  orders        Order[]
  addresses     Address[]
  reviews       Review[]
  wishlist      WishlistItem[]
  notifications Notification[]
  sessions      Session[]

  @@map("users")
}

// ── SESSION ────────────────────────────────────────────────────────
model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ── PRODUCT ────────────────────────────────────────────────────────
model Product {
  id          Int      @id @default(autoincrement())
  name        String
  brand       String
  category    String // "hightech" | "maison" | "beaute" | "sport" | "mode" | "jeux"
  price       Int // Prix en centimes FCFA (ex: 29990 = 299,90 FCFA)
  oldPrice    Int?
  rating      Float    @default(0)
  reviews     Int      @default(0)
  badge       String? // "hot" | "new" | "sale" | "top"
  sold        Int      @default(0)
  stock       Int      @default(100)
  isNew       Boolean  @default(false)
  isActive    Boolean  @default(true)
  description String?
  colors      String? // JSON array stocké en String pour SQLite
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  images        ProductImage[]
  specs         ProductSpec[]
  orderItems    OrderItem[]
  reviewItems   Review[]
  wishlistItems WishlistItem[]

  @@map("products")
}

model ProductImage {
  id        Int    @id @default(autoincrement())
  productId Int
  url       String
  position  Int    @default(0) // 0 = image principale

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model ProductSpec {
  id        Int    @id @default(autoincrement())
  productId Int
  label     String
  value     String
  position  Int    @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_specs")
}

// ── ORDER ──────────────────────────────────────────────────────────
model Order {
  id              String  @id @default(cuid())
  orderNumber     String  @unique // KLI-YYYYMMDD-XXXX
  userId          String?
  // Infos client (pour les commandes invitées aussi)
  clientPrenom    String
  clientNom       String
  clientEmail     String
  clientTelephone String

  // Livraison
  deliveryMethod  String // "standard" | "express"
  shippingAddress String // JSON : { ville, quartier, adresse, instructions }
  shippingCost    Int // en centimes

  // Paiement
  paymentMethod String // "orange" | "mtn" | "wave" | "cash"
  paymentStatus String @default("pending") // "pending" | "paid" | "failed"

  // Totaux
  subtotal Int // somme articles
  discount Int @default(0) // remise promo
  total    Int // total final

  // Promo
  promoCode     String?
  promoDiscount Int     @default(0)

  // Statut commande
  status String @default("pending")
  // "pending" | "confirmed" | "preparing" | "shipped" | "delivered" | "cancelled"

  notes      String? // instructions spéciales client
  adminNotes String? // notes internes

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user  User?       @relation(fields: [userId], references: [id])
  items OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   String
  productId Int
  name      String // snapshot du nom au moment de la commande
  brand     String
  price     Int // snapshot du prix
  qty       Int
  image     String
  color     String?

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

// ── ADDRESS ────────────────────────────────────────────────────────
model Address {
  id        String  @id @default(cuid())
  userId    String
  label     String // "Domicile" | "Bureau" | "Autre"
  prenom    String
  nom       String
  telephone String
  ville     String
  quartier  String?
  adresse   String
  isDefault Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

// ── REVIEW ─────────────────────────────────────────────────────────
model Review {
  id        String   @id @default(cuid())
  userId    String
  productId Int
  rating    Int // 1–5
  title     String?
  body      String
  verified  Boolean  @default(false) // achat vérifié
  helpful   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId]) // 1 avis par utilisateur par produit
  @@map("reviews")
}

// ── WISHLIST ───────────────────────────────────────────────────────
model WishlistItem {
  id        Int      @id @default(autoincrement())
  userId    String
  productId Int
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("wishlist_items")
}

// ── PROMO CODE ─────────────────────────────────────────────────────
model PromoCode {
  id        Int       @id @default(autoincrement())
  code      String    @unique
  type      String // "percent" | "fixed"
  value     Int // % ou centimes FCFA
  minOrder  Int       @default(0)
  maxUses   Int?
  usedCount Int       @default(0)
  isActive  Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  @@map("promo_codes")
}

// ── NOTIFICATION ───────────────────────────────────────────────────
model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String // "order" | "promo" | "system"
  title     String
  body      String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ── CONTACT ────────────────────────────────────────────────────────
model ContactMessage {
  id        String   @id @default(cuid())
  prenom    String
  nom       String
  email     String
  telephone String?
  sujet     String
  message   String
  status    String   @default("new") // "new" | "read" | "replied"
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

// ── BLOG ───────────────────────────────────────────────────────────
model BlogPost {
  id          Int       @id @default(autoincrement())
  slug        String    @unique
  title       String
  excerpt     String
  body        String
  coverImage  String
  category    String
  tags        String // JSON array
  author      String
  authorImage String?
  readTime    Int       @default(5)
  views       Int       @default(0)
  likes       Int       @default(0)
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("blog_posts")
}
