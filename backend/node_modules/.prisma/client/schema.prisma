// ══════════════════════════════════════════════════════════════
//  KOLI — Prisma Schema
//  SQLite en dev · PostgreSQL en prod
// ══════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── ENUMS ──────────────────────────────────────────────────────────
// SQLite ne supporte pas les enums natifs → String + validation Zod

// ── USER ───────────────────────────────────────────────────────────
model User {
  id                     String    @id @default(cuid())
  email                  String    @unique
  password               String
  prenom                 String
  nom                    String
  telephone              String?
  avatar                 String?
  genre                  String? // "Homme" | "Femme" | "Autre"
  naissance              DateTime?
  role                   String    @default("customer") // "customer" | "admin" | "seller"
  isVerified             Boolean   @default(false)
  isBanned               Boolean   @default(false)
  subscribedToNewsletter Boolean   @default(true)

  // ── Fidélité ──────────────────────────────────────────────────
  loyaltyPoints Int @default(0)

  // ── Parrainage ────────────────────────────────────────────────
  referralCode String? @unique // code unique généré à la création
  referredById String? // id du parrain (User)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  orders            Order[]
  addresses         Address[]
  reviews           Review[]
  wishlist          WishlistItem[]
  notifications     Notification[]
  sessions          Session[]
  pointTransactions PointTransaction[]
  stockAlerts       StockAlert[]
  giftLists         GiftList[]
  browseHistory     BrowseHistory[]
  sellerStore       SellerStore?

  @@map("users")
}

// ── SESSION ────────────────────────────────────────────────────────
model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ── STORE ────────────────────────────────────────────────────────
model Store {
  id           Int       @id @default(autoincrement())
  name         String
  logo         String?
  description  String?
  address      String?
  phone        String?
  email        String?
  website      String?
  isActive     Boolean   @default(true)
  lastImportAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  products Product[]

  @@map("stores")
}

// ── SELLER STORE ───────────────────────────────────────────────────
// Boutique gérée par un vendeur (role="seller")
model SellerStore {
  id          Int      @id @default(autoincrement())
  userId      String   @unique
  name        String
  description String?
  logo        String?
  banner      String?
  phone       String?
  address     String?
  isApproved  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  products SellerProduct[]

  @@map("seller_stores")
}

model SellerProduct {
  id         Int      @id @default(autoincrement())
  storeId    Int
  productId  Int
  commission Float    @default(5) // % commission Koli
  isListed   Boolean  @default(true)
  createdAt  DateTime @default(now())

  store   SellerStore @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([storeId, productId])
  @@map("seller_products")
}

// ── PRODUCT ────────────────────────────────────────────────────────
model Product {
  id          Int     @id @default(autoincrement())
  name        String
  brand       String
  category    String // slug "hightech" | "maison" | "beaute" | "sport" | "mode" | "jeux"
  categoryId  Int?
  price       Float
  oldPrice    Float?
  storeId     Int?
  rating      Float   @default(0)
  reviews     Int     @default(0)
  badge       String? // "hot" | "new" | "sale" | "top"
  sold        Int     @default(0)
  stock       Int     @default(100)
  isNew       Boolean @default(false)
  isActive    Boolean @default(true)
  description String?
  colors      String? // JSON array

  // ── Ventes Flash ──────────────────────────────────────────────
  saleEndsAt DateTime? // null = pas en vente flash
  salePrice  Float? // prix pendant la flash sale

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  store          Store?          @relation(fields: [storeId], references: [id])
  categoryRel    Category?       @relation(fields: [categoryId], references: [id])
  images         ProductImage[]
  specs          ProductSpec[]
  orderItems     OrderItem[]
  reviewItems    Review[]
  wishlistItems  WishlistItem[]
  stockAlerts    StockAlert[]
  giftListItems  GiftListItem[]
  browseHistory  BrowseHistory[]
  sellerProducts SellerProduct[]

  @@map("products")
}

model ProductImage {
  id        Int    @id @default(autoincrement())
  productId Int
  url       String
  position  Int    @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model ProductSpec {
  id        Int    @id @default(autoincrement())
  productId Int
  label     String
  value     String
  position  Int    @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_specs")
}

// ── ORDER ──────────────────────────────────────────────────────────
model Order {
  id              String  @id @default(cuid())
  orderNumber     String  @unique
  userId          String?
  clientPrenom    String
  clientNom       String
  clientEmail     String
  clientTelephone String

  deliveryMethod  String
  shippingAddress String
  shippingCost    Float

  paymentMethod String
  paymentStatus String @default("pending")

  subtotal  Float
  discount  Float @default(0)
  taxRate   Float @default(0)
  taxAmount Float @default(0)
  total     Float

  promoCode     String?
  promoDiscount Float   @default(0)

  // ── Fidélité ──────────────────────────────────────────────────
  pointsEarned   Int @default(0)
  pointsRedeemed Int @default(0)

  // ── Paiement fractionné ───────────────────────────────────────
  installmentPlan Boolean @default(false)

  status     String  @default("pending")
  notes      String?
  adminNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User?         @relation(fields: [userId], references: [id])
  items        OrderItem[]
  delivery     Delivery?
  installments Installment[]

  @@map("orders")
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   String
  productId Int
  name      String
  brand     String
  price     Float
  qty       Int
  image     String
  color     String?

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

// ── ADDRESS ────────────────────────────────────────────────────────
model Address {
  id        String  @id @default(cuid())
  userId    String
  label     String
  prenom    String
  nom       String
  telephone String
  ville     String
  quartier  String?
  adresse   String
  isDefault Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

// ── REVIEW ─────────────────────────────────────────────────────────
model Review {
  id        String   @id @default(cuid())
  userId    String
  productId Int
  rating    Int
  title     String?
  body      String
  verified  Boolean  @default(false)
  helpful   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

// ── WISHLIST ───────────────────────────────────────────────────────
model WishlistItem {
  id        Int      @id @default(autoincrement())
  userId    String
  productId Int
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("wishlist_items")
}

// ── PROMO CODE ─────────────────────────────────────────────────────
model PromoCode {
  id        Int       @id @default(autoincrement())
  code      String    @unique
  type      String // "percent" | "fixed"
  value     Float
  minOrder  Float     @default(0)
  maxUses   Int?
  usedCount Int       @default(0)
  isActive  Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  @@map("promo_codes")
}

// ── NOTIFICATION ───────────────────────────────────────────────────
model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String // "order" | "promo" | "system" | "loyalty" | "stock"
  title     String
  body      String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ── CONTACT ────────────────────────────────────────────────────────
model ContactMessage {
  id        String   @id @default(cuid())
  prenom    String
  nom       String
  email     String
  telephone String?
  sujet     String
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

// ── CATEGORY ──────────────────────────────────────────────────────
model Category {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  name        String
  description String?
  icon        String?
  image       String?
  tag         String?
  position    Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@map("categories")
}

// ── TVA ────────────────────────────────────────────────────────────
model TaxRate {
  id        String   @id @default(cuid())
  name      String
  rate      Float
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tax_rates")
}

// ── NEWSLETTER ────────────────────────────────────────────────
model NewsletterSubscriber {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  subscribedAt DateTime @default(now())

  @@map("newsletter_subscribers")
}

// ── BLOG ───────────────────────────────────────────────────────────
model BlogPost {
  id          Int       @id @default(autoincrement())
  slug        String    @unique
  title       String
  excerpt     String
  body        String
  coverImage  String
  category    String
  tags        String
  author      String
  authorImage String?
  readTime    Int       @default(5)
  views       Int       @default(0)
  likes       Int       @default(0)
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("blog_posts")
}

// ══════════════════════════════════════════════════════════════════
//  NOUVELLES FONCTIONNALITÉS
// ══════════════════════════════════════════════════════════════════

// ── 1. FIDÉLITÉ — Transactions de points ──────────────────────────
model PointTransaction {
  id        String   @id @default(cuid())
  userId    String
  orderId   String? // commande source (earn) ou commande bénéficiaire (redeem)
  type      String // "earn" | "redeem" | "referral" | "bonus"
  points    Int // positif = gain, négatif = dépense
  note      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("point_transactions")
}

// ── 4. ALERTE RETOUR EN STOCK ─────────────────────────────────────
model StockAlert {
  id        Int      @id @default(autoincrement())
  userId    String?
  email     String
  productId Int
  sent      Boolean  @default(false)
  createdAt DateTime @default(now())

  user    User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([email, productId])
  @@map("stock_alerts")
}

// ── 7. LISTE DE CADEAUX ────────────────────────────────────────────
model GiftList {
  id        String    @id @default(cuid())
  userId    String
  title     String
  slug      String    @unique
  occasion  String? // "anniversaire" | "mariage" | "noel" | "autre"
  date      DateTime?
  isPublic  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items GiftListItem[]

  @@map("gift_lists")
}

model GiftListItem {
  id          Int      @id @default(autoincrement())
  listId      String
  productId   Int
  isPurchased Boolean  @default(false)
  createdAt   DateTime @default(now())

  list    GiftList @relation(fields: [listId], references: [id], onDelete: Cascade)
  product Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([listId, productId])
  @@map("gift_list_items")
}

// ── 6. SUIVI DE LIVRAISON ─────────────────────────────────────────
model Delivery {
  id          String   @id @default(cuid())
  orderId     String   @unique
  driverName  String?
  driverPhone String?
  steps       String // JSON: [{label, done, timestamp}]
  photo       String? // photo de livraison
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("deliveries")
}

// ── 8. PAIEMENT FRACTIONNÉ ────────────────────────────────────────
model Installment {
  id        String    @id @default(cuid())
  orderId   String
  number    Int // 1, 2, 3
  amount    Float
  dueDate   DateTime
  paidAt    DateTime?
  status    String    @default("pending") // "pending" | "paid" | "overdue"
  createdAt DateTime  @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("installments")
}

// ── 9. HISTORIQUE DE NAVIGATION ───────────────────────────────────
model BrowseHistory {
  id        Int      @id @default(autoincrement())
  userId    String
  productId Int
  viewedAt  DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("browse_history")
}
