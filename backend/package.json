{
  "name": "koli-backend",
  "version": "1.0.0",
  "description": "Koli E-commerce API — Node.js + TypeScript + Prisma",
  "main": "dist/index.js",
  "scripts": {
    "dev": "kill $(lsof -ti :4000) 2>/dev/null; tsx watch src/index.ts",
    "dev:watch": "kill $(lsof -ti :4000) 2>/dev/null; nodemon dist/index.js",
    "build": "tsc",
    "postinstall": "prisma generate",
    "start": "prisma migrate deploy && node dist/index.js",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force && tsx prisma/seed.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@appsignal/nodejs": "^3.8.1",
    "@google-shopping/accounts": "^3.2.1",
    "@google-shopping/products": "^0.9.0",
    "@prisma/client": "^5.14.0",
    "@sentry/node": "^10.67.0",
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-slow-down": "^3.1.0",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "nodemon": "^3.1.14",
    "pdfkit": "^0.19.1",
    "prisma": "^5.14.0",
    "resend": "^6.12.4",
    "sharp": "^0.35.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/hpp": "^0.2.7",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.2.0",
    "@types/node": "^26.1.1",
    "@types/pdfkit": "^0.17.6",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "exceljs": {
      "uuid": "^11.1.1"
    },
    "@opentelemetry/core": "^2.8.0",
    "@opentelemetry/propagator-jaeger": "^2.9.0"
  }
}
