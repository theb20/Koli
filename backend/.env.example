# ─── Serveur ───────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Base de données ────────────────────────────────────────────────
# SQLite (développement) — fichier local, aucune installation requise
DATABASE_URL="file:./dev.db"

# PostgreSQL (production) — décommenter en prod
# DATABASE_URL="postgresql://user:password@localhost:5432/koli_db?schema=public"

# ─── JWT ────────────────────────────────────────────────────────────
JWT_SECRET="koli-super-secret-jwt-key-change-in-production-min-32-chars"
# Access token volontairement court — koili/koli-admin rafraîchissent
# automatiquement en arrière-plan via /api/auth/refresh (cookie httpOnly,
# SameSite=None en prod) dès qu'un appel API répond 401. Le refresh token
# (30j, en rotation, révoqué en bloc à l'expiration/réutilisation) porte
# la persistance de session — pas l'access token.
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── CORS ───────────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:5173"
# En production : FRONTEND_URL="https://koli.cm"

# ─── Email (nodemailer) ──────────────────────────────────────────────
# Gmail — créer un mot de passe d'application sur myaccount.google.com
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="votre@gmail.com"
SMTP_PASS="votre-mot-de-passe-application"
EMAIL_FROM="Koli <service.client@koli.cm>"

# ─── Uploads ────────────────────────────────────────────────────────
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=5

# ─── Admin ──────────────────────────────────────────────────────────
ADMIN_SECRET="admin-bootstrap-secret"

# ─── WhatsApp Business Cloud API (Meta) ────────────────────────────
# Notification automatique à l'équipe (SiteSettings.whatsappNumber) à
# chaque nouvelle commande. Tant que ces variables sont absentes,
# l'envoi est silencieusement ignoré (aucune erreur, commande non bloquée).
# Voir backend/src/lib/whatsapp/client.ts pour la marche à suivre.
# WHATSAPP_ACCESS_TOKEN="jeton d'accès permanent (System User)"
# WHATSAPP_PHONE_NUMBER_ID="ID du numéro expéditeur Cloud API"
# WHATSAPP_API_VERSION="v20.0"
# WHATSAPP_ORDER_TEMPLATE="new_order_notification"
# WHATSAPP_ORDER_TEMPLATE_LANG="fr"

# ─── Export produits (Google Sheets / Apps Script) ────────────────────
# GET /api/products/export — protégé par clé statique, header x-api-key
# ou paramètre ?key=. Générer avec : openssl rand -hex 32
# PRODUCTS_EXPORT_API_KEY="génère une clé aléatoire, ne jamais committer la vraie valeur"

# ─── Google Merchant Center (API Merchant) ─────────────────────────────
# Synchronisation du catalogue vers Google Shopping — déclenchée depuis
# le back-office (Produits → Synchroniser avec Google). Voir
# backend/src/lib/merchantFeed.ts pour le détail. Tant que ces variables
# sont absentes, le bouton de synchro échoue proprement (400), rien ne
# casse ailleurs.
#
# GOOGLE_MERCHANT_ACCOUNT_ID     — ID du compte Merchant Center
# GOOGLE_MERCHANT_DATA_SOURCE_ID — ID numérique de la source de données
#   "API" créée dans Merchant Center → Produits → Ajouter une source de
#   produits → "Ajouter des produits à l'aide de l'API"
# GOOGLE_MERCHANT_CLIENT_EMAIL   — email du compte de service Google Cloud
# GOOGLE_MERCHANT_PRIVATE_KEY    — clé privée du compte de service (le
#   JSON téléchargé contient "\n" littéraux dans private_key — les coller
#   tels quels, le code les convertit en vrais retours à la ligne)
# GOOGLE_MERCHANT_FEED_LABEL     — optionnel, défaut "CI"
# GOOGLE_MERCHANT_SITE_URL       — optionnel, défaut "https://skignas.com".
#   Sert à construire le lien produit envoyé à Google — volontairement
#   indépendant de FRONTEND_URL (qui vaut localhost en dev) : un lien
#   produit qui ne pointe pas vers le domaine validé dans Merchant Center
#   fait échouer la diffusion de TOUS les produits ("URL de la boutique en
#   ligne incohérente").
#
# GOOGLE_MERCHANT_ACCOUNT_ID="5827375243"
# GOOGLE_MERCHANT_DATA_SOURCE_ID=""
# GOOGLE_MERCHANT_CLIENT_EMAIL=""
# GOOGLE_MERCHANT_PRIVATE_KEY=""

# ─── Scan antivirus des fichiers uploadés (Cloudmersive) ───────────────
# Chaque image/fichier reçu sur les routes d'upload (catégories, demandes
# de sourcing, retours, import Excel produits, images rehébergées lors du
# scraping de magasins) est scanné avant d'être écrit sur disque. Voir
# backend/src/lib/virusScan.ts. Tant que cette variable est absente, le
# scan est simplement ignoré (fail-open) — aucun upload existant ne casse.
# Clé gratuite : https://cloudmersive.com/virus-api (compte gratuit, quota
# mensuel suffisant pour le volume actuel du site).
# CLOUDMERSIVE_API_KEY="génère une clé sur ton compte, ne jamais committer la vraie valeur"

# ─── Paiement en ligne (PayDunya) ──────────────────────────────────────
# Remplace orange/mtn/wave par un vrai paiement en ligne : à la création
# d'une commande (POST /api/orders) avec l'une de ces méthodes, une facture
# PayDunya est créée et le client redirigé vers son URL de paiement. PayDunya
# notifie ensuite POST /api/payments/paydunya/ipn — dont le contenu est
# TOUJOURS revérifié auprès de PayDunya avant de marquer une commande payée
# (voir backend/src/lib/paydunya.ts). Tant que ces variables sont absentes,
# "cash" fonctionne normalement et orange/mtn/wave retombent sur l'ancien
# comportement (confirmation manuelle par un admin) — rien ne casse.
#
# 4 clés dans le dashboard PayDunya → Mon compte → API et intégrations.
# PAYDUNYA_MODE : "sandbox" (défaut, paiements de test) ou "live" (argent réel).
#
# PAYDUNYA_MODE="sandbox"
# PAYDUNYA_MASTER_KEY="ne jamais committer la vraie valeur"
# PAYDUNYA_PRIVATE_KEY="ne jamais committer la vraie valeur"
# PAYDUNYA_PUBLIC_KEY="ne jamais committer la vraie valeur"
# PAYDUNYA_TOKEN="ne jamais committer la vraie valeur"

# ─── Suivi d'erreurs (Sentry) ───────────────────────────────────────────
# Chaque logger.error() (utilisé dans toutes les routes) remonte aussi vers
# Sentry si configuré — voir backend/src/lib/logger.ts et
# backend/src/instrument.ts. Tant que SENTRY_DSN est absent, Sentry.init()
# se désactive tout seul, rien ne casse.
# Compte gratuit + DSN : https://sentry.io → New Project → Node.js/Express
# SENTRY_DSN="ne jamais committer la vraie valeur"

# ─── Suivi d'erreurs (AppSignal) ────────────────────────────────────────
# Voir backend/src/appsignal.ts. Tant que la clé est absente, active=false
# et rien n'est envoyé — rien ne casse.
# Compte gratuit + clé "Push API Key" : https://appsignal.com
# APPSIGNAL_PUSH_API_KEY="ne jamais committer la vraie valeur"

# ─── Stockage de fichiers (stockgo) ─────────────────────────────────────
# Service de stockage séparé (dossier stockgo/ à la racine du repo) —
# toutes les nouvelles images uploadées (produits, catégories, retours,
# demandes) partent vers ce service au lieu du disque local du backend.
# Voir backend/src/lib/stockgo.ts. Tant que ces deux variables sont
# absentes, isStockgoConfigured() est false et l'upload échoue proprement.
STOCKGO_URL="https://storage.skignas.com"
# STOCKGO_API_KEY="ne jamais committer la vraie valeur"
