generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String             @id @default(cuid())
  email                  String             @unique
  password               String
  prenom                 String
  nom                    String
  telephone              String?
  avatar                 String?
  genre                  String?
  naissance              DateTime?
  role                   String             @default("customer")
  isVerified             Boolean            @default(false)
  isBanned               Boolean            @default(false)
  subscribedToNewsletter Boolean            @default(true)
  loyaltyPoints          Int                @default(0)
  referralCode           String?            @unique
  referredById           String?
  resetTokenHash         String?            @unique
  resetTokenExpiresAt    DateTime?
  magicTokenHash         String?            @unique
  magicTokenExpiresAt    DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  addresses              Address[]
  browseHistory          BrowseHistory[]
  giftLists              GiftList[]
  notifications          Notification[]
  orders                 Order[]
  orderReturns           OrderReturn[]
  pointTransactions      PointTransaction[]
  productRequests        ProductRequest[]
  reviews                Review[]
  sellerStore            SellerStore?
  sessions               Session[]
  stockAlerts            StockAlert[]
  wishlist               WishlistItem[]

  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Store {
  id           Int       @id @default(autoincrement())
  name         String
  description  String?
  address      String?
  phone        String?
  email        String?
  website      String?
  isActive     Boolean   @default(true)
  lastImportAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  logo         String?
  products     Product[]

  @@map("stores")
}

model SellerStore {
  id          Int             @id @default(autoincrement())
  userId      String          @unique
  name        String
  description String?
  logo        String?
  banner      String?
  phone       String?
  address     String?
  isApproved  Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  products    SellerProduct[]
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("seller_stores")
}

model SellerProduct {
  id         Int         @id @default(autoincrement())
  storeId    Int
  productId  Int
  commission Float       @default(5)
  isListed   Boolean     @default(true)
  createdAt  DateTime    @default(now())
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  store      SellerStore @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, productId])
  @@map("seller_products")
}

model Product {
  id             Int             @id @default(autoincrement())
  name           String
  brand          String
  category       String
  categoryId     Int?
  price          Int
  oldPrice       Int?
  storeId        Int?
  rating         Float           @default(0)
  reviews        Int             @default(0)
  badge          String?
  sold           Int             @default(0)
  stock          Int             @default(100)
  isNew          Boolean         @default(false)
  isActive       Boolean         @default(true)
  description    String?
  colors         String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  saleStartsAt   DateTime?
  saleEndsAt     DateTime?
  salePrice      Int?
  /// Dernier résultat connu d'une synchronisation Merchant (tous providers
  /// confondus) — "success" | "failed" | "skipped" | null si jamais synchronisé.
  merchantSyncStatus String?
  merchantSyncedAt   DateTime?
  browseHistory  BrowseHistory[]
  giftListItems  GiftListItem[]
  orderItems     OrderItem[]
  images         ProductImage[]
  specs          ProductSpec[]
  categoryRel    Category?       @relation(fields: [categoryId], references: [id])
  store          Store?          @relation(fields: [storeId], references: [id])
  reviewItems    Review[]
  sellerProducts SellerProduct[]
  stockAlerts    StockAlert[]
  wishlistItems  WishlistItem[]

  @@index([categoryId])
  @@index([storeId])
  @@index([category])
  @@index([isActive, createdAt])
  /// Tri par défaut du catalogue (GET /api/products sans ?sort=) — le plus
  /// consulté, jusqu'ici sans index dédié malgré isActive+createdAt existant
  /// pour le tri "newest".
  @@index([isActive, sold])
  @@map("products")
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  productId Int
  url       String
  position  Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model ProductSpec {
  id        Int     @id @default(autoincrement())
  productId Int
  label     String
  value     String
  position  Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_specs")
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  clientRequestId String?       @unique
  userId          String?
  clientPrenom    String
  clientNom       String
  clientEmail     String
  clientTelephone String
  deliveryMethod  String
  shippingAddress String
  shippingCost    Int
  paymentMethod   String
  paymentStatus   String        @default("pending")
  /// Token de facture PayDunya — sert à retrouver la commande depuis l'IPN
  /// et à revérifier le statut réel auprès de PayDunya (jamais de confiance
  /// aveugle dans le contenu brut de l'IPN).
  paydunyaToken   String?       @unique
  subtotal        Int
  discount        Int           @default(0)
  taxRate         Float         @default(0)
  taxAmount       Int           @default(0)
  total           Int
  promoCode       String?
  promoDiscount   Int           @default(0)
  pointsEarned    Int           @default(0)
  pointsRedeemed  Int           @default(0)
  installmentPlan Boolean       @default(false)
  status          String        @default("pending")
  notes           String?
  adminNotes      String?
  /// Verrouillé à la première transition vers "delivered" — base du calcul
  /// de la fenêtre d'éligibilité au retour (SiteSettings.returnWindowDays).
  deliveredAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  delivery        Delivery?
  installments    Installment[]
  items           OrderItem[]
  returns         OrderReturn[]
  user            User?         @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id          Int          @id @default(autoincrement())
  orderId     String
  productId   Int
  name        String
  brand       String
  price       Int
  qty         Int
  image       String
  color       String?
  product     Product      @relation(fields: [productId], references: [id])
  order       Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  returnItems OrderReturnItem[]

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

/// Demande de retour — porte sur des articles précis d'une commande (voir
/// OrderReturnItem), jamais la commande entière directement. Machine à états
/// stricte appliquée côté serveur (routes/returns.ts) :
/// requested → approved → received → refunded
///     ↓            ↓          ↓
/// cancelled     rejected   rejected
model OrderReturn {
  id       String @id @default(cuid())
  orderId  String
  userId   String
  /// requested | approved | rejected | received | refunded | cancelled
  status   String @default("requested")
  /// defective | wrong_item | not_as_described | no_longer_needed | other
  reason          String
  customerComment String?
  adminNotes      String?
  rejectionReason String?
  /// JSON: string[] — photos de preuve envoyées par le client, ré-hébergées
  /// côté serveur comme les autres uploads (jamais un lien externe direct).
  photos       String?
  /// Calculé à l'approbation à partir des articles retournés, plafonné au
  /// montant réellement payé — ajustable par l'admin avant remboursement.
  refundAmount Int?
  refundMethod String?
  requestedAt  DateTime  @default(now())
  approvedAt   DateTime?
  rejectedAt   DateTime?
  receivedAt   DateTime?
  refundedAt   DateTime?
  cancelledAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  order        Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  items        OrderReturnItem[]

  @@index([orderId])
  @@index([userId])
  @@index([status])
  @@map("order_returns")
}

model OrderReturnItem {
  id          Int         @id @default(autoincrement())
  returnId    String
  orderItemId Int
  quantity    Int
  orderReturn OrderReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  orderItem   OrderItem   @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([returnId])
  @@index([orderItemId])
  @@map("order_return_items")
}

model Address {
  id        String  @id @default(cuid())
  userId    String
  label     String
  prenom    String
  nom       String
  telephone String
  ville     String
  quartier  String?
  adresse   String
  isDefault Boolean @default(false)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("addresses")
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  productId Int
  rating    Int
  title     String?
  body      String
  verified  Boolean  @default(false)
  helpful   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([userId])
  @@map("reviews")
}

model WishlistItem {
  id        Int      @id @default(autoincrement())
  userId    String
  productId Int
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("wishlist_items")
}

model PromoCode {
  id        Int       @id @default(autoincrement())
  code      String    @unique
  type      String
  value     Int
  minOrder  Int       @default(0)
  maxUses   Int?
  usedCount Int       @default(0)
  isActive  Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  @@map("promo_codes")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

/// Code de vérification e-mail à 6 chiffres pour l'étape 2 du wizard
/// d'inscription marchand (koli-business) — envoyé et vérifié AVANT que le
/// compte User n'existe (créé plus tard, à l'étape 3), donc pas rattachable
/// à un User. Une ligne par email, régénérée à chaque renvoi.
model EmailVerification {
  id          String   @id @default(cuid())
  email       String   @unique
  codeHash    String
  attempts    Int      @default(0)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@map("email_verifications")
}

model ContactMessage {
  id        String   @id @default(cuid())
  prenom    String
  nom       String
  email     String
  telephone String?
  sujet     String
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

/// Demande de sourcing produit ("Trouver un produit") — /demande
model ProductRequest {
  id              String    @id @default(cuid())
  userId          String?
  clientPrenom    String
  clientNom       String
  clientEmail     String
  clientTelephone String?
  productName     String
  description     String
  images          String?   // JSON: string[] (URLs uploadées)
  quantity        Int?
  budget          Int?
  deliveryAddress String
  desiredDate     DateTime?
  status          String    @default("new") // new | processing | quoted | fulfilled | rejected | cancelled
  adminReply      String?
  quotedPrice     Int?
  repliedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User?     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("product_requests")
}

model Category {
  id          Int       @id @default(autoincrement())
  slug        String    @unique
  name        String
  description String?
  icon        String?
  image       String?
  tag         String?
  position    Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@map("categories")
}

model TaxRate {
  id        String   @id @default(cuid())
  name      String
  rate      Float
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tax_rates")
}

model NewsletterSubscriber {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  subscribedAt DateTime @default(now())

  @@map("newsletter_subscribers")
}

model BlogPost {
  id          Int       @id @default(autoincrement())
  slug        String    @unique
  title       String
  excerpt     String
  body        String
  coverImage  String
  category    String
  tags        String
  author      String
  authorImage String?
  readTime    Int       @default(5)
  views       Int       @default(0)
  likes       Int       @default(0)
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("blog_posts")
}

model PointTransaction {
  id        String   @id @default(cuid())
  userId    String
  orderId   String?
  type      String
  points    Int
  note      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("point_transactions")
}

model StockAlert {
  id        Int      @id @default(autoincrement())
  userId    String?
  email     String
  productId Int
  sent      Boolean  @default(false)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([email, productId])
  @@map("stock_alerts")
}

model GiftList {
  id        String         @id @default(cuid())
  userId    String
  title     String
  slug      String         @unique
  occasion  String?
  date      DateTime?
  isPublic  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  items     GiftListItem[]
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("gift_lists")
}

model GiftListItem {
  id          Int      @id @default(autoincrement())
  listId      String
  productId   Int
  isPurchased Boolean  @default(false)
  createdAt   DateTime @default(now())
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  list        GiftList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@unique([listId, productId])
  @@map("gift_list_items")
}

model Delivery {
  id          String   @id @default(cuid())
  orderId     String   @unique
  driverName  String?
  driverPhone String?
  steps       String
  photo       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("deliveries")
}

model Installment {
  id        String    @id @default(cuid())
  orderId   String
  number    Int
  amount    Int
  dueDate   DateTime
  paidAt    DateTime?
  status    String    @default("pending")
  createdAt DateTime  @default(now())
  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("installments")
}

model BrowseHistory {
  id        Int      @id @default(autoincrement())
  userId    String
  productId Int
  viewedAt  DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("browse_history")
}

/// Annonce email automatique d'une vente flash à un segment de clients
model DealAnnouncement {
  id             Int       @id @default(autoincrement())
  productIds     String    // JSON: number[]
  segment        String    // 'all' | 'buyers' | 'inactive'
  inactiveDays   Int?
  sendAt         DateTime
  status         String    @default("pending") // pending | sent | failed | cancelled
  recipientCount Int?
  error          String?
  createdAt      DateTime  @default(now())
  sentAt         DateTime?

  @@map("deal_announcements")
}

/// Réglages globaux du site (singleton — une seule ligne, id fixe = 1)
model SiteSettings {
  id             Int      @id @default(1)
  supportPhone   String   @default("+225 01 41 00 00 12")
  whatsappNumber String   @default("2250700000000")
  supportEmail   String   @default("support@skignas.com")
  contactEmail   String   @default("hello@skignas.com")
  address        String   @default("Cocody, Abidjan - Côte d'Ivoire")
  facebookUrl    String?
  instagramUrl   String?
  youtubeUrl     String?
  tiktokUrl      String?
  /// Destinataires internes des emails "nouvelle commande" — liste séparée par des virgules,
  /// jamais exposée sur GET /api/settings (public)
  orderNotifyEmails String @default("skignass@gmail.com")
  /// Design tokens des emails (back-office → Templates email). NULL = valeur par
  /// défaut codée dans layout.ts. Chaque valeur est validée par liste blanche
  /// avant écriture (voir email-templates.ts) — jamais de HTML/CSS libre.
  emailPrimaryColor       String?
  emailHeaderGradientFrom String?
  emailHeaderGradientTo   String?
  emailCardRadius         Int?
  emailCardBg             String?
  emailBodyBg             String?
  emailFooterText         String?
  emailLogoUrl            String?
  emailLogoWidth          Int?
  emailLogoHeight         Int?
  emailBadgeText          String?
  /// Nombre de jours après livraison pendant lesquels un client peut demander
  /// un retour (voir eligibility check dans returns.ts).
  returnWindowDays Int      @default(14)
  /// Coupe-circuit global du programme de fidélité — quand false, plus aucun
  /// point n'est gagné (commandes, parrainage) ni utilisable (redeem), mais
  /// les soldes/historiques existants restent intacts et consultables.
  loyaltyEnabled   Boolean  @default(true)
  /// Solde minimum de points requis pour pouvoir les utiliser (POST /loyalty/redeem).
  loyaltyMinRedeem Int      @default(500)
  /// Autorise "cash" (paiement à la livraison) comme mode de paiement à la
  /// commande — quand false, seul le paiement en ligne (PayDunya) est proposé.
  codEnabled       Boolean  @default(true)
  updatedAt      DateTime @updatedAt

  @@map("site_settings")
}

/// Journal des actions admin sensibles (rôle, bannissement, suppression...).
/// actorEmail est un instantané (pas une relation) pour rester lisible même
/// si le compte auteur est supprimé par la suite.
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorEmail String?
  action     String
  targetType String
  targetId   String
  metadata   String?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

/// Une exécution de synchronisation catalogue → marketplace (Google Merchant
/// aujourd'hui, provider volontairement en champ String — pas d'enum — pour
/// pouvoir brancher meta/tiktok/pinterest/microsoft plus tard sans migration).
model MerchantSyncRun {
  id           String   @id @default(cuid())
  provider     String   @default("google")
  mode         String   // "full" | "selected" | "retry"
  status       String   @default("running") // "running" | "completed" | "failed"
  actorId      String?
  actorEmail   String?
  total        Int      @default(0)
  succeeded    Int      @default(0)
  failedCount  Int      @default(0)
  skippedCount Int      @default(0)
  startedAt    DateTime @default(now())
  finishedAt   DateTime?
  items        MerchantSyncItem[]

  @@index([provider, status])
  @@index([startedAt])
  @@map("merchant_sync_runs")
}

model MerchantSyncItem {
  id          String   @id @default(cuid())
  runId       String
  run         MerchantSyncRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  productId   Int      // pas de relation FK — snapshot, doit survivre à la suppression du produit
  productName String
  status      String   // "success" | "failed" | "skipped"
  error       String?
  warnings    String?  // JSON string[] — avertissements de préflight (non bloquants)
  createdAt   DateTime @default(now())

  @@index([runId])
  @@index([runId, status])
  @@map("merchant_sync_items")
}
