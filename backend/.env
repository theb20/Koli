# ─── Serveur ───────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Base de données ────────────────────────────────────────────────
# SQLite (développement) — fichier local, aucune installation requise
DATABASE_URL="file:./dev.db"

# PostgreSQL (production) — décommenter en prod
# DATABASE_URL="postgresql://user:password@localhost:5432/koli_db?schema=public"

# ─── JWT ────────────────────────────────────────────────────────────
JWT_SECRET="koli-super-secret-jwt-key-change-in-production-min-32-chars"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── CORS ───────────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:3000"
# En production : FRONTEND_URL="https://koli.cm"

# ─── Email (Resend) ──────────────────────────────────────────────────
RESEND_API_KEY="re_TjvZmY5C_QDy6CanF7JDDd9YAy5T6dbZJ"
# Une fois dropshipp.fr vérifié sur resend.com/domains → changer en :
# EMAIL_FROM="Koli <noreply@dropshipp.fr>"
EMAIL_FROM="Dropship <noreply@dropshipp.fr>"

# ─── Uploads ────────────────────────────────────────────────────────
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=5
# ─── Admin ──────────────────────────────────────────────────────────
ADMIN_SECRET="admin-bootstrap-secret"
# ─── Google OAuth (Firebase Console → Authentication → Google → Web SDK config)
GOOGLE_CLIENT_ID="colle-ton-client-id-ici.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="colle-ton-secret-ici"

