# Port d'écoute HTTP
PORT=8080

# development | production — production active le mode release Gin et les
# logs JSON structurés
ENV=development

# Connexion PostgreSQL dédiée à ce service — ne partage pas la base du
# backend Node principal (bounded context isolé, cf. README).
DATABASE_URL=postgres://merchantgo:merchantgo@localhost:5434/merchantgo_dev?sslmode=disable

# Secret de signature des JWT — DOIT être la même valeur que JWT_SECRET dans
# backend/.env : ce service vérifie les access tokens émis par le backend
# Node principal (même utilisateur, même session), il n'émet pas les siens.
JWT_SECRET=change-me-in-production

# Clé API statique pour koli-admin (validation des candidatures marchand) —
# authentification service-à-service, même mécanisme que stockgo.
ADMIN_API_KEY=change-me-in-production

# Secret partagé de la destination webhook Didit (Business Console → API &
# Webhooks → secret_shared_key) — sert à vérifier X-Signature-V2 sur
# POST /api/v1/webhooks/didit.
DIDIT_WEBHOOK_SECRET=change-me-in-production

# Origines autorisées en CORS, séparées par des virgules — koli-business et
# koli-marchand appellent ce service directement depuis le navigateur.
# Optionnel : une liste par défaut couvrant ces deux apps (local + prod) est
# utilisée si absent — cf. internal/config/config.go.
# ALLOWED_ORIGINS=https://business.skignas.com,https://marchant-e58f1.web.app

# Rate limiting par IP (requêtes/seconde et rafale autorisée)
RATE_LIMIT_RPS=5
RATE_LIMIT_BURST=15
